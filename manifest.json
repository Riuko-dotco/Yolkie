{
  "name": "Yolkie-Adblock",
  "version": "1.0",
  "manifest_version": 3,

  "permissions": [
    "declarativeNetRequest",
    "storage",
    "webRequest",
    "windows"
  ],

  "web_accessibles_resources":[
    {
      "resources": ["./canvas/resources/*"],
      "matches": ["<all_urls"]
    }
  ],
  "icons":{
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "yolkie-background.js"
  },

  "action": {
    "default_popup": "yolkie-OptionsMenu.html"
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "base_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
